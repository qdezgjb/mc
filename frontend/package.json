    "@vueuse/core": "^14.1.0",
    "axios": "^1.7.9",
    "chart.js": "^4.5.1",
    "dompurify": "^3.2.4",
    "echarts": "^5.6.0",
    "element-plus": "^2.13.1",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.11",
    "jspdf": "^4.2.0",
