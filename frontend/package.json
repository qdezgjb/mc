{
  "name": "mindgraph-frontend",
  "private": true,
  "version": "5.94.0",
  "type": "module",
  "scripts": {
    "sync-version": "npx tsx scripts/sync-version.ts",
    "build-prompt-registry": "cd .. && python scripts/build_prompt_language_registry.py",
    "dev": "vite",
    "prebuild": "npm run build-prompt-registry && npm run sync-version",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,js,json,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,js,json,css,scss}\"",
    "check": "vue-tsc --noEmit && npm run lint && npm run format:check",
    "check:fix": "npm run fix && npm run check",
    "i18n:check-keys": "npx tsx scripts/check-i18n-keys.ts",
    "i18n:check-picker-stubs": "npx tsx scripts/check-i18n-picker-stubs.ts",
    "i18n:materialize-from-en": "npx tsx scripts/materialize-locale-bundles-from-en.ts",
    "i18n:build-zhtw": "npx tsx scripts/build-zhtw-from-zh.ts",
    "i18n:translate-from-en": "npx tsx scripts/translate-ui-locales-from-en.ts",
    "i18n:check-prompts": "cd .. && python scripts/check_prompt_output_languages_sync.py",
    "i18n:check": "npm run i18n:check-keys && npm run i18n:check-prompts",
    "i18n:verify-keyboard": "npx tsx scripts/verify-keyboard-layout-map.ts",
    "fix": "npm run lint:fix && npm run format"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "@fontsource/noto-sans": "^5.2.10",
    "@fontsource/noto-sans-arabic": "^5.2.10",
    "@fontsource/noto-sans-armenian": "^5.2.8",
    "@fontsource/noto-sans-bengali": "^5.2.11",
    "@fontsource/noto-sans-devanagari": "^5.2.8",
    "@fontsource/noto-sans-ethiopic": "^5.2.7",
    "@fontsource/noto-sans-georgian": "^5.2.8",
    "@fontsource/noto-sans-gujarati": "^5.2.7",
    "@fontsource/noto-sans-gurmukhi": "^5.2.9",
    "@fontsource/noto-sans-hebrew": "^5.2.8",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@fontsource/noto-sans-kannada": "^5.2.9",
    "@fontsource/noto-sans-khmer": "^5.2.8",
